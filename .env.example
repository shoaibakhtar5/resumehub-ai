APP_NAME="ResumeHub AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================================
# Feature Flags
# ============================================================================
# Control application features without changing code
# All flags can be overridden here, respecting APP_ENV defaults
#
# Development Mode (APP_ENV=local):
# - Email verification disabled by default
# - Speeds up development and testing
# - No SMTP configuration required
#
# Production Mode (APP_ENV=production):
# - Email verification enabled by default
# - All security features active
# ============================================================================

# Email Verification
# false: Skip email verification in development
# true:  Require email verification in production
# Default: false for local, true for production
FEATURE_EMAIL_VERIFICATION=false

# AI Features (Resume review, scoring, cover letter, etc.)
FEATURE_AI=true

# Payment Processing
FEATURE_PAYMENTS=true

# Blog Functionality
FEATURE_BLOG=true

# Analytics Tracking
FEATURE_ANALYTICS=true

# Social Login (Google, LinkedIn, etc.)
FEATURE_SOCIAL_LOGIN=true

# OTP Login
FEATURE_OTP_LOGIN=true

# Notifications System
FEATURE_NOTIFICATIONS=true

# ATS Checker
FEATURE_ATS_CHECKER=true

# Resume Templates
FEATURE_RESUME_TEMPLATES=true

# ============================================================================

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI="${APP_URL}/auth/google/callback"

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI="${APP_URL}/auth/linkedin-openid/callback"

AI_PROVIDER=resumehub-local
AI_MODEL=heuristic-v1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
